{
  "name": "@kaoyan/workspace",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22 <23"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "pnpm --filter @kaoyan/web dev",
    "lint": "pnpm --recursive --if-present lint",
    "typecheck": "pnpm --recursive --if-present typecheck",
    "test": "pnpm --recursive --if-present test",
    "build": "pnpm --recursive --if-present build",
    "test:e2e": "pnpm --filter @kaoyan/web test:e2e"
  }
}
