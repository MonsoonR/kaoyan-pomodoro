{
  "name": "@kaoyan/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@kaoyan/contracts": "workspace:*",
    "better-sqlite3": "12.11.1",
    "drizzle-orm": "0.45.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "^22.10.2",
    "drizzle-kit": "0.31.10",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
