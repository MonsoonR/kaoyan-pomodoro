{
  "name": "@kaoyan/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "build": "tsc --project tsconfig.build.json",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "account:init": "tsx src/cli/account.ts init",
    "account:reset-password": "tsx src/cli/account.ts reset-password",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "pnpm --filter @kaoyan/contracts build && vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.1",
    "@fastify/rate-limit": "^11.1.0",
    "@kaoyan/contracts": "workspace:*",
    "argon2": "^0.44.0",
    "better-sqlite3": "12.11.1",
    "drizzle-orm": "0.45.2",
    "fastify": "^5.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "^22.10.2",
    "drizzle-kit": "0.31.10",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
